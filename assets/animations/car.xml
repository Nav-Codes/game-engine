<!-- Car frame sizes are 100x100 pixels each -->
<animations>
    <!-- Stopped -->
    <stop_facing_north>
        <frame x="700" y="300" w="100" h="100"/>
    </stop_facing_north>
    <stop_facing_east>
        <frame x="700" y="0" w="100" h="100"/>
    </stop_facing_east>
    <stop_facing_south>
        <frame x="700" y="600" w="100" h="100"/>
    </stop_facing_south>
    <stop_facing_west>
        <frame x="0" y="900" w="100" h="100"/>
    </stop_facing_west>

    <!-- Turning -->
    <turn_to_east>
        <frame x="100" y="500" w="100" h="100"/>
        <frame x="200" y="500" w="100" h="100"/>
        <frame x="300" y="500" w="100" h="100"/>
        <frame x="400" y="500" w="100" h="100"/>
        <frame x="500" y="500" w="100" h="100"/>
        <frame x="600" y="500" w="100" h="100"/>
        <frame x="0" y="600" w="100" h="100"/>
        <frame x="100" y="600" w="100" h="100"/>
        <frame x="200" y="600" w="100" h="100"/>
        <frame x="300" y="600" w="100" h="100"/>
        <frame x="400" y="600" w="100" h="100"/>
        <frame x="500" y="600" w="100" h="100"/>
    </turn_to_east>
    <turn_to_west>
        <frame x="500" y="100" w="100" h="100"/>
        <frame x="600" y="100" w="100" h="100"/>
        <frame x="0" y="" w="200" h="100"/>
        <frame x="100" y="" w="200" h="100"/>
        <frame x="200" y="" w="200" h="100"/>
        <frame x="300" y="" w="200" h="100"/>
        <frame x="400" y="" w="200" h="100"/>
        <frame x="500" y="" w="200" h="100"/>
        <frame x="600" y="" w="200" h="100"/>
        <frame x="0" y="" w="300" h="100"/>
        <frame x="100" y="" w="300" h="100"/>
        <frame x="200" y="" w="300" h="100"/>
    </turn_to_west>
    <turn_to_north>
        <frame x="300" y="300" w="100" h="100"/>
        <frame x="400" y="300" w="100" h="100"/>
        <frame x="500" y="300" w="100" h="100"/>
        <frame x="600" y="300" w="100" h="100"/>
        <frame x="0" y="400" w="100" h="100"/>
        <frame x="100" y="400" w="100" h="100"/>
        <frame x="200" y="400" w="100" h="100"/>
        <frame x="300" y="400" w="100" h="100"/>
        <frame x="400" y="400" w="100" h="100"/>
        <frame x="500" y="400" w="100" h="100"/>
        <frame x="600" y="400" w="100" h="100"/>
        <frame x="0" y="500" w="100" h="100"/>
    </turn_to_north>
    <turn_to_south>
        <frame x="0" y="0" w="100" h="100"/>
        <frame x="100" y="0" w="100" h="100"/>
        <frame x="200" y="0" w="100" h="100"/>
        <frame x="300" y="0" w="100" h="100"/>
        <frame x="400" y="0" w="100" h="100"/>
        <frame x="500" y="0" w="100" h="100"/>
        <frame x="600" y="0" w="100" h="100"/>
        <frame x="0" y="100" w="100" h="100"/>
        <frame x="100" y="100" w="100" h="100"/>
        <frame x="200" y="100" w="100" h="100"/>
        <frame x="300" y="100" w="100" h="100"/>
        <frame x="400" y="100" w="100" h="100"/>
    </turn_to_south>

    <!-- Driving -->
    <drive_north>
        <frame x="700" y="300" w="100" h="100"/>
        <frame x="800" y="300" w="100" h="100"/>
        <frame x="900" y="300" w="100" h="100"/>
        <frame x="1000" y="300" w="100" h="100"/>
        <frame x="700" y="400" w="100" h="100"/>
        <frame x="800" y="400" w="100" h="100"/>
        <frame x="900" y="400" w="100" h="100"/>
        <frame x="1000" y="400" w="100" h="100"/>
        <frame x="700" y="500" w="100" h="100"/>
        <frame x="800" y="500" w="100" h="100"/>
        <frame x="900" y="500" w="100" h="100"/>
        <frame x="1000" y="500" w="100" h="100"/>
    </drive_north>
    <drive_east>
        <frame x="700" y="0" w="100" h="100"/>
        <frame x="800" y="0" w="100" h="100"/>
        <frame x="900" y="0" w="100" h="100"/>
        <frame x="1000" y="0" w="100" h="100"/>
        <frame x="700" y="100" w="100" h="100"/>
        <frame x="800" y="100" w="100" h="100"/>
        <frame x="900" y="100" w="100" h="100"/>
        <frame x="1000" y="100" w="100" h="100"/>
        <frame x="700" y="200" w="100" h="100"/>
        <frame x="800" y="200" w="100" h="100"/>
        <frame x="900" y="200" w="100" h="100"/>
        <frame x="1000" y="200" w="100" h="100"/>
    </drive_east>
    <drive_south>
        <frame x="700" y="600" w="100" h="100"/>
        <frame x="800" y="600" w="100" h="100"/>
        <frame x="900" y="600" w="100" h="100"/>
        <frame x="1000" y="600" w="100" h="100"/>
        <frame x="700" y="700" w="100" h="100"/>
        <frame x="800" y="700" w="100" h="100"/>
        <frame x="900" y="700" w="100" h="100"/>
        <frame x="1000" y="700" w="100" h="100"/>
        <frame x="700" y="800" w="100" h="100"/>
        <frame x="800" y="800" w="100" h="100"/>
        <frame x="900" y="800" w="100" h="100"/>
        <frame x="1000" y="800" w="100" h="100"/>
    </drive_south>
    <drive_west>
        <frame x="0" y="900" w="100" h="100"/>
        <frame x="100" y="900" w="100" h="100"/>
        <frame x="200" y="900" w="100" h="100"/>
        <frame x="300" y="900" w="100" h="100"/>
        <frame x="0" y="1000" w="100" h="100"/>
        <frame x="100" y="1000" w="100" h="100"/>
        <frame x="200" y="1000" w="100" h="100"/>
        <frame x="300" y="1000" w="100" h="100"/>
        <frame x="0" y="1100" w="100" h="100"/>
        <frame x="100" y="1100" w="100" h="100"/>
        <frame x="200" y="1100" w="100" h="100"/>
        <frame x="300" y="1100" w="100" h="100"/>
    </drive_west>
</animations>